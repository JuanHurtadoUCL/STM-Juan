    end
        
    end


pan2 =uipanel(fig_choose,'units','normalized','position',[0.0476 0.1232 0.9036 0.3674]);
txt_par = uicontrol('Parent',pan2,'style','text','units','normalized','position',[-0.0137 0.8250 0.3473 0.1886],...
