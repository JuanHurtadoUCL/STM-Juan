if modulation ==1
    txt_question = uicontrol('Parent',pan1,'style','text','units','normalized','position',[0.0710 0.8059 0.8500 0.1601],...
    'String','Piezo-Stop Measurement','FontSize',15);
    disp('Piezo Stop M')

else
txt_question = uicontrol('Parent',pan1,'style','text','units','normalized','position',[0.0710 0.8059 0.8500 0.1601],...
    'String','Current-Distance Measurement','FontSize',15);
end
