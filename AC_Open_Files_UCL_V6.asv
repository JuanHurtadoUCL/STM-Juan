% Try Import UCL Files
% This script reads the .csv files and transform it to a .mat structure
% with the G and the Z of all of the measured traces

function main

current = fileparts(mfilename('fullpath'));


%selpath = uigetdir();
%str1 = strfind(selpath,'\');
%if selpath(str1(end)+1:str1(end)+3)=='Mod'
%    modulation = 1;
%    save_filename = ['Mod_25V_Molecule_' selpath(str1(end)+5:end) '.mat'];  % This is the name of the saved file
%else
%    save_filename = ['0V_Molecule_' selpath(str1(end)+5:end) '.mat'];  % This is the name of the saved file
%    modulation = 0;
%end
%cd(selpath)

Vb=0.030;                             % Vbias (As appears in the lockin box)
G0=7.748e-5;
modulation = 0;
%num_trace=[9053 21158];            % Number of the traces. First one and Last One
curva=[];
ind=0;
G_tot=[];
Z_tot=[];
Vth_tot =[];
RS = [];
remove=0;
remove_file=0;
remove_top=0;
remove_botom=0;
remove_modulation=0;
div_cut=100;
sgolay_filter = 20;
Rs_calculated = 1.087e6;
Gain_Resistor=1e8;                             % Gain resistance
factor_piezo= 1; % volts to nm
divisor_piezo = 1; % Divisor piezo
cse=20e-11;  % 4.3e-11
freq=3.123e3;
Pt_resistor_tip = 1090; % PT resistance Ohm
Pt_resistor_substrate = 1090; % PT resistance Ohm
Temp_tip = temperature_resistor(Pt_resistor_tip);
Temp_substrate = temperature_resistor(Pt_resistor_substrate);
number_traces = [];
%number_traces = length(({dir(fullfile(selpath,'AcX*.csv')).name}));
off_bool = 0; % 0 if automatic, 1 if manual
cal_trace =1;
offsets_struct=[];
meas_type=1;
Data_lockin_together=[];
pathfile_meas = 'No measurement path file';
pathfile_offset_contact = 'No measurement path file';
pathfile_offset_out = 'No measurement path file';
save_file_name = 'No name';
retraction= 1;
cut_div_val = 20;
%save_filename = [date 'order' num2str(sgolay_filter) 'OPE3_Lockin_15V_25mV.mat'];



fig_main = figure('units','normalized','position',[0.1328 0.2398 0.7536 0.5463]);
rutaCompleta = 'C:\Users\hurtadogalle\OneDrive - UCL\Documents\STM-Juan\STM_Logo.png'; % O 'subcarpeta/datos.csv'
if exist(rutaCompleta, 'file') == 2
    disp('El archivo existe en la ruta especificada.');
    img = imread(rutaCompleta);
    ax_img=axes(fig_main,'Units','normalized','Position',[0.0162 0.0153 0.0588 0.1144]);
    image(img);
    xlabel(ax_img,[]);
    ylabel(ax_img,[]);
    xticks(ax_img,[]);
    yticks(ax_img,[]);
end
pan_measurement =uipanel(fig_main,'units','normalized','position',[0.0130 0.5228 0.4849 0.3676],'Title','Measurement File','FontSize',11);
pan_calibration =uipanel(fig_main,'units','normalized','position',[0.0130 0.14 0.4849 0.3676],'Title','Calibration Capacitor','FontSize',11);
pan_offsets =uipanel(fig_main,'units','normalized','position',[0.5038 0.5228 0.4849 0.3676],'Title','Offset Method','FontSize',11);
pan_variables =uipanel(fig_main,'units','normalized','position',[0.5038 0.14 0.4849 0.3676],'Title','Variables','FontSize',11);
txt_main=uicontrol(fig_main,'style','text','units','normalized','position',[0.0130 0.9042 0.2832 0.0746],...
    'String',' AC Open Files Interface','FontSize',15,'HorizontalAlignment','left','BackgroundColor',[0.89 0.77 0.97],'FontName','Arial Black');

% Panel Measurement

pop_meas_type = uicontrol('Parent',pan_measurement,'style','popupmenu','units','Normalized','Position',[0.0797 0.8212 0.1688 0.1203],...
    'String',{'Lock-in','Python'},'Value',meas_type,'Callback',@fun_pop_meas_type);
    function fun_pop_meas_type(~,~)
        val = pop_meas_type.Value;
        str = pop_meas_type.String;
        str{val};
        disp(['Selection: ' str{val}]);
        meas_type = val;
    end
txt_meas_type = uicontrol('Parent',pan_measurement,'style','text','units','Normalized','Position',[0.2682 0.7463 0.2730 0.2041],...
    'String','Choose file type');
txt_load_pathfile_meas = uicontrol('Parent',pan_measurement,'style','text','units','Normalized','Position',[0.0152 0.5517 0.3166 0.1577],...
    'String','Load the file path','FontSize',10,'HorizontalAlignment','left');
txt_pathfile_meas = uicontrol('Parent',pan_measurement,'style','text','units','Normalized','Position',[0.2481 0.1970 0.5198 0.2404],...
    'String',pathfile_meas,'HorizontalAlignment','left');
txt_number_traces = uicontrol('Parent',pan_measurement,'style','text','units','Normalized','Position',[0.0152 0.0592 0.5198 0.1291],...
    'String','No number of traces. Load file.','HorizontalAlignment','left');
but_load_pathfile_meas = uicontrol('Parent',pan_measurement,'style','pushbutton','units','Normalized','Position',[0.0769 0.2859 0.1458 0.1734],...
    'String','Load','Callback',@fun_load_pathfile_meas);
    function fun_load_pathfile_meas(~,~)
        pathfile_meas = uigetdir();
        txt_pathfile_meas.String = pathfile_meas;
        ind_sep = strfind(pathfile_meas,'\');
        save_file_name=pathfile_meas(ind_sep(end)+1:end);
        edit_file_title.String = save_file_name;
        switch meas_type
            case 1 % Lockin

                Data_lockin_together=join_files(pathfile_meas);
                index_top  = findpeaks(smooth(Data_lockin_together.Piezo_total),'MinPeakProminence',0.1);
                number_traces=length(index_top)-1;
                txt_number_traces.String = ['Number of traces = ' num2str(number_traces)];
               
            case 2  % Python

                 folder_trace_dc = ({dir(fullfile(pathfile_meas,'Dc*.csv')).name});
                 number_traces = length(folder_trace_dc);
                 txt_number_traces.String = ['Number of traces = ' num2str(number_traces)];

        end

    end
but_do_analysis = uicontrol('Parent',pan_measurement,'style','ToggleButton','units','Normalized','Position',[0.6933 0.0399 0.3000 0.1734],...
    'String','Do Analysis','FontSize',11,'Callback',@fun_but_do_analysis);
    function fun_but_do_analysis(~,~)
 set(but_do_analysis,'BackgroundColor',[1 0.6 0]); % naranja
    drawnow;
        switch meas_type
            case 1 % Lockin
                if rb1_offsets.Value==1
                    offsets_struct=calculate_offsets(pathfile_offset_contact,pathfile_offset_out);
                end
                g_total=Conductance_AC(Data_lockin_together,offsets_struct,freq,Rs_calculated,cse,sgolay_filter);
                
                vth_total = thermovoltage_calculator(g_total,Data_lockin_together.DC_total,offsets_struct,Rs_calculated,...
                    Gain_Resistor,Temp_tip,Temp_substrate,sgolay_filter);
                DT=Temp_tip-Temp_substrate;
                [curva_ind,curva_ret] =cut_traces(g_total,vth_total,Data_lockin_together,factor_piezo,DT);
                if retraction ==1
                    curva = curva_ret;
                else
                    curva = curva_ind;
                end
                  set(but_do_analysis,'BackgroundColor',[0.94 0.94 0.94]);
                drawnow;
              
                ind_sep = strfind(pathfile_meas,'\');
                pathfile_save = pathfile_meas(1:ind_sep(end)-1);
                save([pathfile_save '\' save_file_name],'curva', '-v7.3')
                AC_Clustering_UCL_Conductance_V4(curva,[pathfile_meas '\' save_file_name])

            case 2  % Python

                folder_trace_dc = ({dir(fullfile(pathfile_meas,'Dc*.csv')).name}) ;
                folder_trace_acx = ({dir(fullfile(pathfile_meas,'AcX*.csv')).name}) ;
                folder_trace_acy = ({dir(fullfile(pathfile_meas,'AcY*.csv')).name}) ;
                folder_piezo = ({dir(fullfile(pathfile_meas,'piezo*.csv')).name});

                for i= 1:length(folder_piezo)
               % for i= 1:10

                    file_piezo= folder_piezo{i};
                    file_trace_dc= folder_trace_dc{i};
                    file_trace_acx= folder_trace_acx{i};
                    file_trace_acy= folder_trace_acy{i};

                    if isempty(file_piezo)
                        continue
                    end

                    piezo_bit = csvread([pathfile_meas,'\',file_piezo]);
                    traces_bit_dc = csvread([pathfile_meas,'\',file_trace_dc]);
                    traces_bit_acx = csvread([pathfile_meas,'\',file_trace_acx]);
                    traces_bit_acy = csvread([pathfile_meas,'\',file_trace_acy]);

                    piezo_raw = piezo_bit(2:end-1).*(10/32768)-10;             % Bit to volt function of 16 bits Adwin
                    traces_dc = traces_bit_dc(2:end-1).*(10/8388608)-10;       % Bit to volt function of 24 bits Adwin
                    traces_acx_rms = traces_bit_acx(1:end).*(10/8388608)-10;   % Bit to volt function of 24 bits Adwin
                    traces_acy_rms = traces_bit_acy(1:end).*(10/8388608)-10;   % Bit to volt function of 24 bits Adwin

                    traces_acy = traces_acy_rms(2:end-1);              % Rms values to peak to peak change
                    traces_acx = traces_acx_rms(2:end-1);              % Rms values to peak to peak change
                    piezo_volt = piezo_raw./divisor_piezo;                                % Voltage divisor at the Adwin output 1/50
                    piezo = piezo_volt*factor_piezo;                                 % Volts to m conversion 2.4e-8 [m/V]

                    if size(traces_acx)<310
                        continue
                    end
                    if rb3_offsets.Value==1
                        g_ac = Conductance_AC_each_offset(traces_acx,traces_acy,cse,Rs_calculated,freq,sgolay_filter,cut_div_val);
                        vth_total = thermovoltage_calculator_each_offset(g_ac,traces_dc,Rs_calculated,Gain_Resistor,Temp_tip,Temp_substrate,sgolay_filter,cut_div_val);

                    else
                        g_ac = Conductance_AC(traces_acx,traces_acy,offsets_struct,freq,Rs_calculated,cse,sgolay_filter);  % nm, G/G0
                        vth_total = thermovoltage_calculator(g_ac,traces_dc,offsets_struct,Rs_calculated,...
                            Gain_Resistor,Temp_tip,Temp_substrate,sgolay_filter);
                        piezo_moved=-move_zero(g_ac,piezo);
                        DT=Temp_tip-Temp_substrate;


                        log_g=log10(abs(real(g_ac))./G0);
                        top_g=mean(log_g(20:120));
                        botom_g=mean(log_g(end-120:end-20));
                    end

                    if top_g<-0.5
                        remove=remove+1;
                        remove_top=remove_top+1;
                        continue
                    end
                    if botom_g>-4
                        remove=remove+1;
                        remove_botom=remove_botom+1;
                        continue
                    end
                    

                    if size(log_g)==size(piezo_moved)     % Creation of the final saved structure
                        ind=ind+1;
                        curva(ind).g=abs(real(g_ac))./G0;   % Conductance G/G0
                        curva(ind).z=piezo_moved;                     % Distance nm
                        curva(ind).piezoV=piezo_moved;         % Distance Volts
                        curva(ind).vth=vth_total;                 % Thermovoltage mV
                        curva(ind).Temp=DT;                 % Temperature K
                        % G_tot=[G_tot;G_ac];
                        % Vth_tot=[Vth_tot;Vth];
                        % Z_tot=[Z_tot; Z];
                    end
                end
                curva(1).Info.Vbias = {[num2str(Vb) ' mV']};
                disp(['Removed traces: ' num2str(remove)]);
                disp(['Removed traces File: ' num2str(remove_file)]);
                disp(['Removed traces Top: ' num2str(remove_top)]);
                disp(['Removed traces Botom: ' num2str(remove_botom)]);
                disp(['Removed traces Modulation: ' num2str(remove_modulation)]);
                disp(['Collected traces: ' num2str(length(curva))]);
                set(but_do_analysis,'BackgroundColor',[0.94 0.94 0.94]);
                drawnow;
              
                save([pathfile_meas '\' save_file_name],'curva', '-v7.3')
                AC_Clustering_UCL_Conductance_V4(curva,[pathfile_meas '\' save_file_name])


        end
    end

radio_retraction = uibuttongroup('Parent',pan_measurement,'units','Normalized','Position',[0.5900 0.6928 0.4000 0.2949]);
rb1_retraction = uicontrol('Parent',radio_retraction,'style','radiobutton','units','normalized','Position',[0.0500 0.3022 0.4155 0.4300],...
    'String','Retraction','FontSize',9,'Callback',@fun_rb1_retraction);
    function fun_rb1_retraction(~,~)
        retraction = 1;
    end
rb1_ind = uicontrol('Parent',radio_retraction,'style','radiobutton','units','normalized','Position',[0.5327 0.3022 0.4346 0.4300],...
    'String','Aproach','FontSize',9,'Callback',@fun_rb1_ind);
    function fun_rb1_ind(~,~)
        retraction = 0;
    end
