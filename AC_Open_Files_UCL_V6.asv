rb2_offsets = uicontrol('Parent',radio_group_offsets,'style','radiobutton','units','normalized','Position',[0.2645 0.3022 0.3240 0.4300],...
    'String','Offset Specific Trace','FontSize',10,'Callback',@fun_radio_offset_ind_trace);
